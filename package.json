{
  "name": "ultracode",
  "version": "0.1.3",
  "description": "Portable ultracode: dynamic multi-agent workflow orchestration for Codex, Qoder, Claude Code, Gemini CLI and other coding agents",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "ultracode": "dist/cli/main.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "skill",
    "workflows",
    "hostpacks"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:plugins": "node scripts/build-plugins.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.24.0",
    "acorn": "^8.14.0",
    "ajv": "^8.17.0",
    "commander": "^13.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.19.0",
    "vitest": "^3.0.0"
  }
}
