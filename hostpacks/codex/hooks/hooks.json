{
  "description": "Load portable ultracode project memory when a Codex session starts or compacts.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "ultracode memory hook",
            "timeout": 10,
            "statusMessage": "Loading project memory"
          }
        ]
      }
    ]
  }
}
