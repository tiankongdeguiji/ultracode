+"""Pure policy helpers injected by the Ultracode FeatureBench adapter."""
+
+import json
+from collections.abc import Mapping
+from typing import Any
+
+
+WORKFLOW_CLEANUP_SCRIPT = r'''set -u
+scan_runs() {
+  result=$(ULTRACODE_SCAN_MODE="$1" /opt/bench/node-sel - <<'NODE'
+const fs = require('node:fs');
+const path = require('node:path');
+const home = '/agent-logs/ultracode';
+const verified = new Set(['completed', 'failed', 'stopped']);
+const recovery = new Set(['orphaned', 'cleanup-failed']);
+const mode = process.env.ULTRACODE_SCAN_MODE;
+const runs = path.join(home, 'runs');
+if (!fs.existsSync(runs)) process.exit(3);
+const entries = fs.readdirSync(runs, { withFileTypes: true })
+  .filter((entry) => entry.isDirectory());
+if (entries.length === 0) process.exit(3);
+for (const entry of entries) {
+  const runId = entry.name;
+  try {
+    const manifest = JSON.parse(fs.readFileSync(path.join(runs, runId, 'manifest.json'), 'utf8'));
+    const status = String(manifest.status);
+    if (mode === 'all' || (mode === 'recovery' && recovery.has(status)) || (mode === 'active' && !verified.has(status))) {
+      console.log(runId);
+    }
+  } catch { if (mode === 'active' || mode === 'all') console.log(runId); }
+}
+NODE
+  )
+  status=$?
+  if [ "$status" -eq 3 ]; then
+    printf '__no_ultracode_runs__\n' >&2
+    return 1
+  fi
+  if [ "$status" -ne 0 ]; then
+    printf '__workflow_scan_failed__\n' >&2
+    return 1
+  fi
+  printf '%s' "$result"
+}
+stop_runs() {
+  failed=0
+  for run_id in $1; do
+    ULTRACODE_HOME=/agent-logs/ultracode /opt/bench/node-sel \
+      /opt/bench/ultracode/dist/cli/main.js stop "$run_id" >&2 || failed=1
+  done
+  [ "$failed" -eq 0 ]
+}
+recover_workflows() {
+  recovery=$(scan_runs recovery) || return 1
+  if [ -z "$recovery" ]; then return 0; fi
+  printf 'recovering unverified workflows: %s\n' "$recovery" >&2
+  stop_runs "$recovery" || return 1
+  remaining_recovery=$(scan_runs recovery) || return 1
+  [ -z "$remaining_recovery" ] || {
+    printf 'workflow cleanup remains unverified: %s\n' "$remaining_recovery" >&2
+    return 1
+  }
+}
+recover_workflows || exit 1
+stragglers=$(scan_runs active) || exit 1
+deadline=$(( $(date +%s) + FEATUREBENCH_WORKFLOW_WAIT_SECONDS ))
+while [ -n "$stragglers" ] && [ "$(date +%s)" -lt "$deadline" ]; do
+  sleep 5
+  recover_workflows || exit 1
+  stragglers=$(scan_runs active) || exit 1
+done
+if [ -z "$stragglers" ]; then
+  all_runs=$(scan_runs all) || exit 1
+  printf 'verifying workflow process cleanup: %s\n' "$all_runs" >&2
+  stop_runs "$all_runs" || exit 1
+  recover_workflows || exit 1
+  exit 0
+fi
+printf 'workflow wait expired; stopping: %s\n' "$stragglers" >&2
+stop_runs "$stragglers" || exit 1
+stop_deadline=$(( $(date +%s) + 120 ))
+recover_workflows || exit 1
+remaining=$(scan_runs active) || exit 1
+while [ -n "$remaining" ] && [ "$(date +%s)" -lt "$stop_deadline" ]; do
+  sleep 5
+  recover_workflows || exit 1
+  remaining=$(scan_runs active) || exit 1
+done
+[ -z "$remaining" ] || printf 'workflows did not stop: %s\n' "$remaining" >&2
+exit 1'''
+
+
+def toml_string(value: str) -> str:
+    """Encode one exact TOML basic string using JSON-compatible escapes."""
+
+    if not isinstance(value, str):
+        raise TypeError("TOML value must be a string")
+    return json.dumps(value, ensure_ascii=False)
+
+
+def container_limits(source: Mapping[str, str], purpose: str) -> tuple[int, int, int]:
+    """Parse mandatory Docker CPU, memory, and PID ceilings."""
+
+    try:
+        nano_cpus = int(float(source.get("FB_CONTAINER_CPUS") or "") * 1_000_000_000)
+        memory_limit = int(source.get("FB_CONTAINER_MEMORY") or "")
+        pids_limit = int(source.get("FB_CONTAINER_PIDS") or "")
+    except (OverflowError, TypeError, ValueError) as exc:
+        raise RuntimeError(f"Invalid FeatureBench {purpose} resource limits") from exc
+    if nano_cpus <= 0 or memory_limit <= 0 or pids_limit <= 0:
+        raise RuntimeError(f"Positive FeatureBench {purpose} resource limits are required")
+    return nano_cpus, memory_limit, pids_limit
+
+
+def attest_container_policy(
+    host_config: Any,
+    limits: tuple[int, int, int],
+    expected_network: str | None = None,
+) -> None:
+    """Require Docker to report the exact requested runtime policy."""
+
+    nano_cpus, memory_limit, pids_limit = limits
+    if (
+        not isinstance(host_config, dict)
+        or expected_network is not None and host_config.get("NetworkMode") != expected_network
+        or host_config.get("NanoCpus") != nano_cpus
+        or host_config.get("Memory") != memory_limit
+        or host_config.get("PidsLimit") != pids_limit
+    ):
+        raise RuntimeError("FeatureBench container runtime attestation failed")
+
+
+def output_copy_plan(arm: str, workflows_complete: bool) -> tuple[tuple[str, str], ...]:
+    """Keep host billing artifacts independent from mutable workflow output."""
+
+    if arm not in {"a", "b"}:
+        raise RuntimeError("Invalid FeatureBench arm")
+    copies = [
+        ("/agent-logs/codex_events.jsonl", "codex_events.jsonl"),
+        ("/root/.codex/sessions", "codex_sessions"),
+    ]
+    if arm == "b" and workflows_complete:
+        copies.append(("/agent-logs/ultracode", "ultracode"))
+    return tuple(copies)
